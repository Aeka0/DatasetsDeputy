{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Datasets Deputy",
  "version": "0.1.0",
  "identifier": "com.datasetsdeputy.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Datasets Deputy",
        "create": false,
        "width": 1360,
        "height": 860,
        "minWidth": 1120,
        "minHeight": 720,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": true
      },
      {
        "label": "splash",
        "title": "Datasets Deputy",
        "url": "/splash.html",
        "width": 1344,
        "height": 768,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false,
        "center": true,
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": [],
    "externalBin": [],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
